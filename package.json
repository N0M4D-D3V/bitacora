{
  "name": "bitacora-cli",
  "version": "2.0.0",
  "description": "CLI for scaffolding and maintaining the Bitacora agent harness and memory layer.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "bitacora": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "README_dev.md"
  ],
  "scripts": {
    "dev": "tsup src/index.ts --watch",
    "build": "tsup && mkdir -p dist/templates && cp -Rf templates/. dist/templates",
    "cli": "node dist/index.js",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "format": "biome format . --write",
    "clean": "rm -rf dist coverage"
  },
  "keywords": [
    "agents",
    "ai",
    "bitacora",
    "cli",
    "developer-tools",
    "harness",
    "memory"
  ],
  "author": "SK3L3TR",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/N0M4D-D3V/bitacora.git"
  },
  "homepage": "https://github.com/N0M4D-D3V/bitacora#readme",
  "bugs": {
    "url": "https://github.com/N0M4D-D3V/bitacora/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.0.9",
  "dependencies": {
    "bitacora-cli": "link:",
    "commander": "^14.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/node": "^25.6.2",
    "@vitest/coverage-v8": "^4.1.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
